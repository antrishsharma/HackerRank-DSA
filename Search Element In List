#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
int x;
    scanf("%d",&x);
    int index=-1;
    for(int i=0;i<n;i++){
        if(arr[i]==x){
            index=i;
            break;
        }
    }
  if(index!=-1){
      printf("Found");
  }
    else{
        printf("Not Found");
    }
    
    return 0;
}
