#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int count0=0;
    int count1=0;
    
    int sandwitch[n];
    int student[n];
    
    for(int i=0;i<n;i++){
        scanf("%d",&student[i]);
        if(student[i]==0){
            count0++;
        }
        else{
            count1++;
        }
    }
    
    for(int i=0;i<n;i++){
        scanf("%d",&sandwitch[i]);
    }
    
    for(int i=0;i<n;i++){
        if(sandwitch[i]==0){
            if(count0==0){
                break;
            }
                count0--;
            
        }
        else{
            if(count1==0){
                break;
            }
            count1--;
        }
    }
    printf("%d",count0+count1);
    return 0;
}

