#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    int x;
    scanf("%d",&x);
    int k=0;
    for(int i=0;i<n;i++){
        if(arr[i]!=x){
            arr[k]=arr[i];
            k++;
        }
    }
    
    for(int i=0;i<k;i++){
        printf("%d ",arr[i]);
    }
    return 0;
}
