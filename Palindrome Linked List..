#include<stdio.h>
int main(){
    int n,a[10];
    scanf("%d",&n);
    for(int i=0;i<n;i++){scanf("%d",&a[i]);}
    int flag = 1;
    for(int i=0;i<n/2;i++)if(a[i]!=a[n-i-1]){flag=0;break;}
        
    if(flag)printf("Palindrome : ");
    else printf("Not Palindrome : ");
    
    for(int i=n-1;i>=0;i--){
        printf("%d",a[i]);
        if(i!=0){printf(" ");}
    }
    return 0;
}
