#include<stdio.h>
int main(){
    int n,e;
    scanf("%d",&n);
    scanf("%d",&e);
    int m[10][10]={0};
    
    for( int i=0;i<e;i++){
        int u,v;
        scanf("%d %d",&u,&v);
        m[u][v]=1;
        m[v][u]=1;
    }
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(j>0)printf(" ");
            printf("%d",m[i][j]);
        }printf("\n");
    }return 0;}
