#include<stdio.h>
#define Max 100
int stack[Max];
int top=-1;
int size;

void push( int value){
    if (top==size-1){
        printf("Overflow\n");
    }
    else{
        top++;
        stack[top]=value;
    }
}
void pop(){
    if (top==-1){
        printf("Underflow\n");
    }
    else{
        printf("Popped: %d\n",stack[top]);
        top--;
    }
}

void display(){
    if(top==-1){
        printf("Stack is Empty\n");
    }
    else{
        for(int i=top;i>=0;i--){
            printf("%d ",stack[i]);
        }
    }
}

int main(){
    int value;
    scanf("%d",&size);
    int n;
    scanf("%d",&n);
    
    
    
    for(int i=0;i<n;i++){
        scanf("%d",&value);
        push(value);
    }
pop();
    pop();
    
     for(int i=0;i<4;i++){
        scanf("%d",&value);
        push(value);
    }
pop();

    
    for(int i=0;i<2;i++){
        scanf("%d",&value);
        push(value);
    }
 pop();
    pop();
    pop();

    display();
    return 0;
}

