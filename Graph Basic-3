#include <stdio.h>

int main() {
    int n, e;
    scanf("%d", &n);
    scanf("%d", &e);

    int m[10][10] = {0};

    for (int i = 0; i < e; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        m[u][v] = 1;
        m[v][u] = 1;
    }

    int s;
    scanf("%d", &s);

    int stack[100];
    int top = -1;
    int visited[10] = {0};

    // push starting vertex
    stack[++top] = s;

    while (top >= 0) {
        int node = stack[top--];   // pop from top

        if (visited[node]) continue;  // skip if already visited
        visited[node] = 1;
        printf("%d ", node);

        // push neighbors in DECREASING order
        // so smallest gets popped first
        for (int j = n - 1; j >= 0; j--) {
            if (m[node][j] == 1 && visited[j] == 0) {
                stack[++top] = j;
            }
        }
    }

    return 0;
}
