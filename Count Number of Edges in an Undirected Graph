#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int m[10][10];

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &m[i][j]);

    int count = 0;

    for (int i = 0; i < n; i++)
        for (int j = i + 1; j < n; j++)  // j starts from i+1 (upper triangle only)
            if (m[i][j] == 1)
                count++;

    printf("%d", count);
    return 0;
}
