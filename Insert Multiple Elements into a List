#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int arr[100];

    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int K;
    scanf("%d", &K);

    for(int j = 0; j < K; j++) {
        int X, P;
        scanf("%d %d", &X, &P);

        for(int i = n - 1; i >= P; i--) {
            arr[i + 1] = arr[i];
        }

        arr[P] = X;
        n++;
    }

    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
